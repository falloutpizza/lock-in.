{
    "manifest_version": 3,
    "name": "lock in.",
    "version": "1.0",
    "description": "a productivity tool that lets users start timed study sessions with breaks after each session.",
    "icons": {
        "48": "icons/placeholder.png"
    },
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "tabs"
    ],
    "action": {
        "default_icon": "icons/placeholder.png",
        "default_title": "lock in. - a focus timer",
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background.js",
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script.js"
            ],
            "css": [
                "content-script.css"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; media-src 'self'"
    }
}