{
    "manifest_version": 3,
    "name": "lock in.",
    "version": "1.0",
    "description": "a productivity tool that lets users start timed study sessions with breaks after each session.",
    "icons": {
        "48": "icons/timer.png"
    },
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "tabs"
    ],
    "action": {
        "default_icon": "icons/timer.png",
        "default_title": "lock in. - a focus timer",
        "default_popup": "popup/popup.html"
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script.js"
            ],
            "css": [
                "content-script.css"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "sounds/notif.mp3"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@lock-in-a-productivity-extension",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}